HOST=0.0.0.0
PORT=1337
PUBLIC_URL=https://cms.example.com
FRONTEND_ORIGIN=https://www.niagarat.com

# Generate strong, unique values locally. Never commit cms/.env.
APP_KEYS=replace-with-four-comma-separated-random-values
API_TOKEN_SALT=replace-with-random-value
ADMIN_JWT_SECRET=replace-with-random-value
TRANSFER_TOKEN_SALT=replace-with-random-value
JWT_SECRET=replace-with-random-value
CMS_WEBHOOK_SECRET=replace-with-the-same-value-as-STRAPI_REVALIDATE_SECRET-on-the-Next-site

DATABASE_URL=
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=hyper_cms
DATABASE_USERNAME=hyper_cms
DATABASE_PASSWORD=replace-with-a-strong-database-password
DATABASE_SCHEMA=public
DATABASE_SSL=false
DATABASE_SSL_SELF=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
